{
  appId: "com.cde.clinique",
  productName: "CDE",
  directories: {
    output: "release/${version}",
  },
  files: ["dist", "dist-electron"],
  win: {
    target: ["nsis"],
    icon: "public/icon.png",
  },
  mac: {
    target: ["dmg"],
    icon: "public/icon.png",
  },
  linux: {
    target: ["AppImage"],
    icon: "public/icon.png",
  },
  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true,
  },
}
